; Substrate Desktop 3D — Godot 4 mycopunk live wallpaper
; Forward+ (Vulkan) renderer with SDFGI, SSAO, SSR, volumetric fog

[application]

config/name="Substrate Desktop 3D"
run/main_scene="res://main.tscn"
config/features=PackedStringArray("4.3")

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/borderless=true
window/vsync/vsync_mode=1

[rendering]

renderer/rendering_method="forward_plus"

[audio]

driver/enable_input=true

[shader_globals]

cursor_world_pos={
"type": "vec3",
"value": "Vector3(0, 0, 0)"
}

audio_bass={
"type": "float",
"value": "0.0"
}

